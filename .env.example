# Copy this file to .env.local and set unique values before using the admin panel.
# Do not commit .env.local or reuse these variable names as literal credentials.
DATABASE_URL=postgresql://deal:change-this-password@localhost:5432/deal
# Set to true when the PostgreSQL host requires TLS (for example, most managed providers).
DATABASE_SSL=false
DEAL_ADMIN_USERNAME=admin
DEAL_ADMIN_PASSWORD=123456123456
DEAL_ADMIN_SECRET=M123456123456M123456123456
